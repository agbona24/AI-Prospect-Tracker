# MySQL database — required for auth + prospect storage
# Format: mysql://USER:PASSWORD@HOST:3306/DBNAME
DATABASE_URL=

# NextAuth — required for session security (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Public production domain — drives canonical URLs, sitemap.xml, robots.txt, and OG tags.
# Set this to the real domain once live (e.g. https://runvax.com); falls back to localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Places API (New) — required for business search
GOOGLE_PLACES_API_KEY=

# OpenAI — required for AI outreach, proposals, briefs
OPENAI_API_KEY=

# Gemini — free tier, 1,500 req/day — https://aistudio.google.com/
GEMINI_API_KEY=

# Groq — free tier, ultra-fast Llama 3.3 — https://console.groq.com/
GROQ_API_KEY=

# AI provider routing (optional — defaults to openai)
# Options: openai | gemini | groq
AI_PROVIDER_DEFAULT=openai
AI_PROVIDER_BRIEF=gemini
AI_PROVIDER_OUTREACH=openai

# Google Custom Search — OPTIONAL email discovery (currently dormant / not needed)
GOOGLE_CSE_ID=
GOOGLE_CSE_KEY=

# Brave Search — OPTIONAL whole-web email discovery
BRAVE_SEARCH_KEY=

# Resend — free SMTP relay, 3,000 emails/month — https://resend.com/
# When set, takes priority over SMTP_HOST/PORT/USER/PASS below
RESEND_API_KEY=

# SMTP — fallback email delivery (used when RESEND_API_KEY is not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# Paystack — https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Create plans in Paystack dashboard → Products → Subscriptions → Plans
PAYSTACK_PRO_PLAN_CODE=
PAYSTACK_AGENCY_PLAN_CODE=

# Admin — comma-separated email addresses that get admin access
ADMIN_EMAILS=

# WhatsApp Business API — template name used when creating/sending the outreach template.
# Optional — defaults to 'runvax_outreach_v1'. Change only if you need a different template name in Meta.
WHATSAPP_TEMPLATE_NAME=

# Sentry — https://sentry.io (optional but strongly recommended for production)
# Create a Next.js project at sentry.io and paste the DSN here
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Cron security — generate: openssl rand -hex 32
# Must match the Authorization header sent by Vercel Cron: Bearer <CRON_SECRET>
CRON_SECRET=
