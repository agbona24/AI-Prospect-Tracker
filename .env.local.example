# Google Places API (New) — required for business search
# 1. Go to https://console.cloud.google.com/
# 2. Create/select a project → APIs & Services → Enable APIs
# 3. Search "Places API (New)" and enable it
# 4. Go to Credentials → Create API Key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Maps JavaScript API — powers the inline map preview in the search form.
# Separate, browser-exposed key — restrict by HTTP referrer, enable "Maps JavaScript API" + "Geocoding API".
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_js_api_key_here

# Anthropic API — required for generating Lovable prompts
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
