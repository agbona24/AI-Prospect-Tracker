generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  name           String?
  email          String?       @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  plan                    String        @default("free")
  paystackCustomerCode    String?
  paystackSubscriptionCode String?
  planExpiresAt           DateTime?
  searchLimitOverride     Int?          // null = use plan default; set to override daily search limit
  blockedLocations        String? @db.Text  // JSON string[] of blocked location keywords
  blockedCountries        String? @db.Text  // JSON string[] of blocked country codes e.g. ["NG","GH"]
  registrationIp          String?           // IP address captured at signup
  lastSeenIp              String?           // IP address from most recent sign-in
  isSuspended             Boolean       @default(false)  // blocks sign-in and API usage when true
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  accounts       Account[]
  sessions       Session[]
  prospects      Prospect[]
  settings       UserSettings?
  dailyLogs      DailyLog[]
  usageRecords        UsageRecord[]
  searchHistory       SearchHistory[]
  payments                Payment[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  demoSites               DemoSite[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Prospect {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId     String
  businessName   String
  businessData   Json
  stage          String         @default("found")
  notes          String?        @db.Text
  score             Int?
  estimatedPriceMin Int?
  estimatedPriceMax Int?
  savedAt           DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  outreachSentAt   DateTime?
  reminderDate     String?
  reminderNote     String?
  followUpSequence Json?
  conversations    Conversation[]

  @@unique([userId, businessId])
}

model Conversation {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  type       String
  channel    String
  content    String   @db.Text
  replyType  String?
  framework  String?
  createdAt  DateTime @default(now())
}

model UserSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Prospecting goals
  dailyGoal    Int      @default(10)
  avgDealValue Int      @default(300000)
  closeRatePct Int      @default(10)

  // Sender identity — used in proposals, email signatures, outreach
  senderName   String?
  businessName String?
  whatsapp     String?
  replyEmail   String?
  city         String?
  tagline      String?
  jobTitle     String?
  website      String?

  // Custom SMTP — overrides platform SMTP when filled in
  smtpHost     String?
  smtpPort     Int?
  smtpUser     String?
  smtpPass     String?  @db.Text
  smtpFrom     String?

  // Bank / payment details — printed in proposals
  bankName      String?
  bankAccount   String?
  bankAcctName  String?
  paymentLink   String?

  // Rate card — JSON blob storing packages, maintenance plans, add-ons, and payment terms
  rateCard     Json?

  // Onboarding
  onboardingDone Boolean @default(false)

  updatedAt    DateTime @updatedAt
}

model DailyLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   String
  count  Int    @default(0)

  @@unique([userId, date])
}

model UsageRecord {
  id                  String @id @default(cuid())
  userId              String
  user                User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                String
  aiCalls             Int    @default(0)
  searchCount         Int    @default(0)
  // Token tracking for cost calculation
  openaiInputTokens   Int    @default(0)
  openaiOutputTokens  Int    @default(0)
  geminiInputTokens   Int    @default(0)
  geminiOutputTokens  Int    @default(0)
  // Google Places API requests (each search can make up to 3 paginated requests)
  googlePlacesReqs    Int    @default(0)

  @@unique([userId, date])
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reference String   @unique
  plan      String
  amount    Int
  status    String   @default("success")
  paidAt    DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model SearchHistory {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  industry       String
  location       String
  totalCount     Int      @default(0)
  noWebsiteCount Int      @default(0)
  searchedAt     DateTime @default(now()) @updatedAt

  @@unique([userId, industry, location])
  @@index([userId])
}

model PlanConfig {
  id               String   @id @default(cuid())
  planId           String   @unique
  name             String   @default("")
  price            String?
  priceNote        String   @default("per month")
  searchesPerDay   Int
  resultsPerSearch Int
  aiCallsPerDay    Int
  maxProspects     Int
  // Comma-separated feature ids the plan unlocks. NULL = fall back to code defaults.
  features         String?  @db.Text
  // JSON string[] of allowed location keywords. NULL = all locations allowed.
  allowedLocations String?  @db.Text
  // JSON string[] of allowed country codes e.g. ["NG","KE"]. NULL = all countries allowed.
  allowedCountries String?  @db.Text
  updatedAt        DateTime @updatedAt
}

model DemoSite {
  id           String   @id @default(cuid())
  slug         String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId   String
  businessName String
  data         Json
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, businessId])
  @@index([userId])
}
